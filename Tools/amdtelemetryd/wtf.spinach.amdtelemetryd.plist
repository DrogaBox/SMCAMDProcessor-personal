<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>wtf.spinach.amdtelemetryd</string>
    <key>ProgramArguments</key>
    <array>
        <string>/usr/local/bin/amdtelemetryd</string>
    </array>
    <key>RunAtLoad</key>
    <true/>
    <key>KeepAlive</key>
    <true/>
    <key>StandardOutPath</key>
    <string>/Users/droga/Library/Logs/amdtelemetryd.log</string>
    <key>StandardErrorPath</key>
    <string>/Users/droga/Library/Logs/amdtelemetryd.err</string>
</dict>
</plist>
